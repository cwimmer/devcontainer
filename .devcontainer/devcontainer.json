{
    "name": "Existing Dockerfile",

    "build": {
        "context": "..",
        "dockerfile": "../Dockerfile.OpenCode"
    },

    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.makefile-tools",
                "redhat.vscode-yaml",
                "DavidAnson.vscode-markdownlint",
                "sst-dev.opencode"
            ]
        }
    },

    "mounts": [
        "source=devcontainer-opencode-data,target=/root/.local/share/opencode,type=volume"
    ]
}
